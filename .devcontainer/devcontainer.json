{
  "name": "ProfPracInIT Codespace",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bookworm",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot App",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-21",
            "path": "/usr/local/sdkman/candidates/java/current",
            "default": true
          }
        ],
        "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current"
      }
    }
  },
  "postCreateCommand": "chmod +x ./mvnw .devcontainer/post-start.sh && ./mvnw -q -DskipTests dependency:go-offline",
  "postStartCommand": ".devcontainer/post-start.sh && ./mvnw -q -v",
  "postAttachCommand": ".devcontainer/post-start.sh"
}
