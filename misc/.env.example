# Mail configuration (required to send emails)
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
APP_MAIL_FROM=no-reply@example.com

# Database configuration
# For local development you can use H2:
SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# For Supabase, replace the three datasource values above with your JDBC connection details.
# Example:
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your_supabase_database_password

# Optional overrides
# SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
# SPRING_MAIL_PORT=2525
